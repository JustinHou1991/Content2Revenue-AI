# Content2Revenue AI - 环境变量配置示例
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# API配置（至少配置一个）
# ============================================

# OpenAI API (可选)
OPENAI_API_KEY=sk-your-openai-key-here

# DeepSeek API (推荐，性价比高)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 通义千问 API (可选)
TONGYI_API_KEY=sk-your-tongyi-key-here

# ============================================
# 数据库配置
# ============================================

# SQLite数据库路径（Docker环境使用绝对路径）
DATABASE_PATH=/app/data/content2revenue.db

# 数据库加密密钥（自动生成，首次启动时设置）
# DB_ENCRYPTION_KEY=your-encryption-key-here

# ============================================
# 日志配置
# ============================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志目录
LOG_DIR=/app/logs

# ============================================
# 备份配置
# ============================================

# 备份目录
BACKUP_DIR=/app/backups

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# ============================================
# 应用配置
# ============================================

# 环境: development, production
ENVIRONMENT=production

# 应用密钥（用于Session加密，请生成随机字符串）
# APP_SECRET_KEY=your-random-secret-key-here

# ============================================
# Streamlit配置
# ============================================

# 服务器端口
STREAMLIT_SERVER_PORT=8501

# 服务器地址
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# 无头模式（禁用浏览器自动打开）
STREAMLIT_SERVER_HEADLESS=true

# 禁用使用统计
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# ============================================
# 高级配置（可选）
# ============================================

# 缓存TTL（秒）
CACHE_TTL=3600

# 最大并发请求数
MAX_CONCURRENT_REQUESTS=5

# LLM请求超时（秒）
LLM_REQUEST_TIMEOUT=60

# 请求重试次数
REQUEST_RETRY_COUNT=3
