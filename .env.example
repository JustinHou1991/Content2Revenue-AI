# Content2Revenue AI - 环境变量配置示例
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# API配置（至少配置一个）
# ============================================

# LongCat API (默认模型)
LONGCAT_API_KEY=sk-your-longcat-key-here

# DeepSeek API (推荐，性价比高)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 通义千问 API (可选)
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# 商汤日日新 API (可选)
SENSNOVA_API_KEY=sk-your-sensenova-key-here

# 通用 API Key（当使用非内置模型时）
C2R_API_KEY=sk-your-api-key-here

# ============================================
# 模型配置
# ============================================

# 默认模型名称
C2R_DEFAULT_MODEL=LongCat-2.0-Preview

# LLM 参数
C2R_MODEL=LongCat-2.0-Preview
C2R_TEMPERATURE=0.3
C2R_MAX_TOKENS=4096
C2R_MAX_RETRIES=3

# ============================================
# 数据库配置
# ============================================

# SQLite数据库路径（Docker环境使用绝对路径）
C2R_DB_PATH=data/c2r.db

# 数据库加密密钥（自动生成，首次启动时设置）
# DB_ENCRYPTION_KEY=your-encryption-key-here

# ============================================
# 日志配置
# ============================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
C2R_LOG_LEVEL=INFO

# 日志目录
C2R_LOG_DIR=data/logs

# 日志文件
C2R_LOG_FILE=data/logs/c2r.log

# 日志文件大小限制（字节）
C2R_LOG_MAX_BYTES=10485760

# 日志备份数量
C2R_LOG_BACKUP_COUNT=5

# ============================================
# 匹配配置
# ============================================

# 匹配返回数量
C2R_MATCH_TOP_K=3

# 匹配并发数
C2R_MATCH_CONCURRENCY=8

# ============================================
# 仪表盘配置
# ============================================

# 仪表盘最近记录限制
C2R_DASHBOARD_RECENT_LIMIT=10

# ============================================
# Streamlit配置
# ============================================

# 服务器端口
STREAMLIT_SERVER_PORT=8501

# 服务器地址
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# 无头模式（禁用浏览器自动打开）
STREAMLIT_SERVER_HEADLESS=true

# 禁用使用统计
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false